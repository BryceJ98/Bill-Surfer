# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Used server-side only
SUPABASE_JWT_SECRET=your-jwt-secret               # Found in Supabase > Settings > API

# Key encryption — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KEY_ENCRYPTION_SECRET=your-32-byte-base64-fernet-key

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
